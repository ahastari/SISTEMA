{
    admin off
}

:{$PORT} {
    root * /app/public

    # Servir archivos estáticos primero
    file_server

    # Procesar PHP con FrankenPHP
    php_server

    # Cachear assets de Vite
    @assets {
        path /build/* /css/* /js/* /images/*
    }
    header @assets Cache-Control "public, max-age=31536000, immutable"
}
